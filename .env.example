# Shared secret with the Ordinat Dashboard (Next.js). Must be the SAME value
# as RECAP_SERVICE_TOKEN in ordinat-dashboard/.env — it's one shared secret
# used in both directions (Flask -> Next.js webhook, Next.js -> Flask proxy).
RECAP_SERVICE_TOKEN="ganti-dengan-token-acak-panjang"

# Local dev only. Set to 1/true to enable Flask's interactive debugger.
# NEVER enable in production — it's a remote-code-execution surface.
# FLASK_DEBUG=1
